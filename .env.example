# =========================================================
# TechBridge Collective — Environment Variables
# Copy to .env.local for local dev. NEVER commit .env.local
# =========================================================

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://techbridgecollective.org  # no trailing slash

# ── Database (Neon / Postgres) ─────────────────────────────
DATABASE_URL=postgresql://techbridge:techbridge@localhost:5432/techbridge

# ── Clerk Auth ─────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional redirect overrides
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Chatbase (H.K. AI widget) ──────────────────────────────
NEXT_PUBLIC_CHATBASE_BOT_ID=3ylVDc3243y5659rIjvcd  # public bot ID
CHATBOT_IDENTITY_SECRET=                            # NEVER expose client-side

# ── Role automation ────────────────────────────────────────
# Comma-separated emails auto-assigned on first login
ADMIN_EMAILS=you@example.com
NAVIGATOR_EMAILS=

# ── Email (partner invites) ────────────────────────────────
EMAIL_PROVIDER=resend          # resend | postmark | none
INVITE_EMAIL_FROM=invites@techbridgecollective.org
EMAIL_SEND_TIMEOUT_MS=10000
INVITE_EMAIL_MAX_ATTEMPTS=5

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=         # svix webhook verification

# Postmark (alternative)
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_WEBHOOK_BASIC_USER=   # basic auth for webhook endpoint
POSTMARK_WEBHOOK_BASIC_PASS=

# ── Cron jobs (Vercel Cron) ────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=                   # required — cron routes return 401 without this

# invite-retry cron tuning (*/10 * * * *)
INVITE_CRON_BATCH=50
INVITE_RETRY_BASE_SECONDS=300       # 5 min base backoff
INVITE_RETRY_MAX_SECONDS=86400      # 24h cap
INVITE_NOT_SENT_RETRY_SECONDS=3600  # 1h before first retry for NOT_SENT

# prune cron tuning (17 3 * * *)
PRUNE_KEEP_CRONRUNS=2000
PRUNE_KEEP_WEBHOOK_EVENTS=50000

# ── Deploy (GitHub Secrets only, not .env) ─────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
