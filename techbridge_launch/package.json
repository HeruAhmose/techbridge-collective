{
  "name": "techbridge-collective",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:real": "CHATBASE_E2E_REAL=1 playwright test",
    "format": "prettier -w .",
    "vercel-build": "prisma migrate deploy && prisma generate && next build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.18.0",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "next": "14.2.5",
    "pdfkit": "0.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "2.5.2",
    "clsx": "2.1.1",
    "lucide-react": "0.461.0",
    "zod": "3.23.8",
    "@clerk/nextjs": "^6.36.0",
    "jszip": "^3.10.1",
    "svix": "^1.33.0",
    "recharts": "2.12.7"
  },
  "devDependencies": {
    "@playwright/test": "1.47.2",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.10",
    "@types/pdfkit": "0.13.6",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.45",
    "prettier": "3.3.3",
    "prisma": "5.18.0",
    "tailwindcss": "3.4.10",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "@types/jszip": "^3.4.7"
  },
  "engines": {
    "node": ">=20"
  }
}
