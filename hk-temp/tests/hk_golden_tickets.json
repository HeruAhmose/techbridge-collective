    {
      "id": "GT-016",
      "title": "Multiple issues in one request",
      "category": "complex",
      "input": {
        "channel": "chat",
        "request_text": "My wifi keeps disconnecting and also I can't print anything and I think someone might have hacked my facebook",
        "requester": { "user_id": "usr_test_016", "role": "customer", "org_id": "hub_durham_library", "tier": "standard" }
      },
      "expected": {
        "should_prioritize_security": true,
        "primary_classification": { "category": "security", "subcategory": "account_compromise" },
        "should_address_all_issues": true,
        "should_triage_security_first": true,
        "secondary_issues_noted": ["network", "hardware"]
      },
      "tags": ["complex", "multi-issue", "security-priority"]
    },
    {
      "id": "GT-017",
      "title": "Emotional/frustrated user",
      "category": "sentiment",
      "input": {
        "channel": "chat",
        "request_text": "I'M SO FRUSTRATED! This stupid computer won't do ANYTHING right! I've been trying for HOURS to get on the internet and NOTHING works! I'm about to throw this thing in the trash!",
        "requester": { "user_id": "usr_test_017", "role": "customer", "org_id": "hub_raleigh_dip", "tier": "standard" }
      },
      "expected": {
        "must_acknowledge_emotion": true,
        "tone": "empathetic",
        "must_not_be_dismissive": true,
