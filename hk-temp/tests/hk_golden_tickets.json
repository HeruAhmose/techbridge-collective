    {
      "id": "GT-019",
      "title": "Known outage — should deflect with status",
      "category": "outage_deflection",
      "input": {
        "channel": "chat",
        "request_text": "I can't access Gmail at all. Is it down?",
        "requester": { "user_id": "usr_test_019", "role": "customer", "org_id": "hub_durham_library", "tier": "standard" }
      },
      "mock_context": {
        "active_incidents": [{ "service": "Gmail", "status": "investigating", "eta": "2 hours", "url": "https://status.google.com" }]
      },
      "expected": {
        "should_check_status_page": true,
        "should_deflect_with_status": true,
        "must_contain": ["known issue", "investigating", "status"],
        "should_not_troubleshoot": true,
        "classification": { "category": "app", "subcategory": "app_crash" },
        "severity": "S2"
      },
      "tags": ["outage", "deflection", "status-page"]
    },
    {
      "id": "GT-020",
      "title": "Technical user — skip basics",
      "category": "adaptive_complexity",
      "input": {
        "channel": "chat",
        "request_text": "Getting SAML assertion error after IdP redirect. Okta logs show status code INVALID_SESSION. Cleared cookies, tried incognito, same result. Using Chrome 121 on macOS 14.3.",
        "requester": { "user_id": "usr_test_020", "role": "employee", "org_id": "hub_durham_library", "tier": "standard" },
        "env": { "device": { "os": "macOS", "os_version": "14.3" }, "app": { "name": "Chrome", "version": "121" } }
      },
      "expected": {
        "classification": { "category": "access_identity", "subcategory": "sso_login_failure" },
        "severity": "S3",
        "priority": "P3",
        "confidence_range": [0.80, 0.95],
        "tone": "technical",
        "must_not_suggest": ["clear cookies", "try incognito"],
        "should_ask_about": ["SAML assertion details", "IdP session timeout config", "SP metadata"],
        "should_reference_kb": true
      },
      "tags": ["technical", "adaptive-complexity", "identity"]
    }
