{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/invite-retry",
      "schedule": "5 3 * * *"
    },
    {
      "path": "/api/cron/prune",
      "schedule": "17 3 * * *"
    }
  ],
  "buildCommand": "prisma generate && next build"
}
