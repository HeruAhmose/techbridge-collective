generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PUBLIC
  PARTNER
  NAVIGATOR
  ADMIN
}

enum TechOutcome {
  RESOLVED
  NEEDS_HELP
  FOLLOW_UP
}

enum InviteEmailStatus {
  NOT_SENT
  SENT
  DELIVERED
  FAILED
}

enum CronRunStatus {
  STARTED
  SUCCESS
  FAILED
  SKIPPED
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  role        UserRole @default(PUBLIC)
  createdAt   DateTime @default(now())

  techMinutes        TechMinute[]
  partnerMemberships PartnerMembership[]

  @@index([role])
}

model PartnerOrganization {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  hubs          HubLocation[]
  memberships   PartnerMembership[]
  PartnerInvite PartnerInvite[]
}

model PartnerMembership {
  id           String   @id @default(cuid())
  partnerOrgId String
  userId       String
  createdAt    DateTime @default(now())

  partnerOrg PartnerOrganization @relation(fields: [partnerOrgId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partnerOrgId, userId])
  @@index([userId])
  @@index([partnerOrgId])
}

model PartnerInvite {
  id               String    @id @default(cuid())
  partnerOrgId     String
  email            String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  consumedAt       DateTime?
  consumedByUserId String?

  emailStatus        InviteEmailStatus @default(NOT_SENT)
  emailProvider      String?
  emailMessageId     String?
  emailAttempts      Int               @default(0)
  emailLastAttemptAt DateTime?
  emailDeliveredAt   DateTime?
  emailLastError     String?

  partnerOrg          PartnerOrganization  @relation(fields: [partnerOrgId], references: [id], onDelete: Cascade)
  emailDeliveryEvents EmailDeliveryEvent[]

  @@unique([partnerOrgId, email])
  @@index([email])
  @@index([partnerOrgId])
  @@index([consumedAt])
  @@index([emailMessageId])
  @@index([emailStatus])
  @@index([emailStatus, emailLastAttemptAt])
  @@index([consumedAt, emailStatus, emailLastAttemptAt])
}

model EmailDeliveryEvent {
  id         String   @id @default(cuid())
  provider   String
  messageId  String?
  inviteId   String?
  eventType  String
  payload    Json
  receivedAt DateTime @default(now())

  invite PartnerInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([messageId])
  @@index([inviteId])
  @@index([receivedAt])
}

model CronRun {
  id         String        @id @default(cuid())
  jobName    String
  status     CronRunStatus @default(STARTED)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  durationMs Int?
  locked     Boolean       @default(true)

  attempted   Int     @default(0)
  processed   Int     @default(0)
  skipped     Int     @default(0)
  errorsCount Int     @default(0)
  lastError   String?

  meta Json?

  @@index([jobName, startedAt])
  @@index([status])
  @@index([startedAt])
}

model HubLocation {
  id           String   @id @default(cuid())
  name         String   @unique
  address      String
  city         String
  state        String
  zip          String
  notes        String?
  partnerOrgId String?
  createdAt    DateTime @default(now())

  partnerOrg PartnerOrganization? @relation(fields: [partnerOrgId], references: [id], onDelete: SetNull)

  schedules        HubSchedule[]
  techMinutes      TechMinute[]
  residentRequests ResidentRequest[]

  @@index([city, state])
  @@index([partnerOrgId])
}

model HubSchedule {
  id            String  @id @default(cuid())
  hubLocationId String
  dayOfWeek     Int // 0=Sun..6=Sat
  startTime     String // "10:00"
  endTime       String // "13:00"
  cadence       String  @default("Weekly")
  isActive      Boolean @default(true)

  hubLocation HubLocation @relation(fields: [hubLocationId], references: [id], onDelete: Cascade)

  @@index([hubLocationId, dayOfWeek])
}

model ResidentRequest {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  name                   String?
  email                  String?
  phone                  String?
  language               String   @default("EN")
  category               String
  description            String
  preferredHubLocationId String?
  preferredTime          String?
  status                 String   @default("NEW")

  preferredHubLocation HubLocation? @relation(fields: [preferredHubLocationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
}

model PartnerRequest {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  organization String
  contactName  String
  email        String
  phone        String?
  city         String?
  notes        String?
  status       String   @default("NEW")

  @@index([createdAt])
  @@index([status])
}

model TechMinute {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  hubLocationId   String
  navigatorUserId String
  minutes         Int
  category        String
  outcome         TechOutcome
  resolution      String?
  isEscalated     Boolean     @default(false)

  hubLocation HubLocation @relation(fields: [hubLocationId], references: [id], onDelete: Restrict)
  navigator   User        @relation(fields: [navigatorUserId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([category])
  @@index([outcome])
  @@index([hubLocationId, createdAt])
}
